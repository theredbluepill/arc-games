# Online / public leaderboard: https://three.arcprize.org — only online games are ratable.
# For that mode, set your key and switch to online (leave as-is for local-only work).
ARC_API_KEY=
ARC_OPERATION_MODE=normal
# ARC_OPERATION_MODE=online
# Optional: specific game ID (e.g., 'ls20-cb3b57cc'). If empty, auto-discovers available games
ARC_GAME_ID=

# Kaggle Benchmarks (for local runs of arc_ez01_task)
# Get MODEL_PROXY_API_KEY from https://www.kaggle.com/models-api-onboarding-packet
# MODEL_PROXY_URL=https://mp-staging.kaggle.net/models/openapi
# MODEL_PROXY_API_KEY=your_token
# LLM_DEFAULT=google/gemini-2.5-flash
